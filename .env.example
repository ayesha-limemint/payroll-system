# Copy this to .env and fill in your values
# Never commit .env to Git

DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Drive folder ID
# Find this in the URL when you open the Payroll System folder on Drive:
# https://drive.google.com/drive/folders/<THIS_IS_YOUR_FOLDER_ID>
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# GitHub token (repo scope)
GITHUB_TOKEN=your-github-token-here

# Google credentials: uses Application Default Credentials (ADC)
# No file needed — run this once in your terminal to authenticate:
#   gcloud auth application-default login
# Make sure to include these scopes:
#   https://www.googleapis.com/auth/drive
#   https://www.googleapis.com/auth/gmail.send
